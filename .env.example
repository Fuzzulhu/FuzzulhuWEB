# Supabase Configuration Template
# Renombra este archivo a .env y completa con tus credenciales

# URL de tu proyecto Supabase (ej: https://xyz.supabase.co)
SUPABASE_URL=your-project-url

# Service Role Key (Se encuentra en Project Settings -> API)
# ¡IMPORTANTE! No compartas esta clave, otorga acceso total a la DB.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Project Reference (Opcional para algunas herramientas, ej: xyz)
SUPABASE_PROJECT_REF=your-project-ref

# Personal Access Token (PAT) - Necesario para Management API
# Se crea en Account Settings -> Access Tokens
SUPABASE_ACCESS_TOKEN=your-access-token
